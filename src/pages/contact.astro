---
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';

const ctas = [
  {
    eyebrow: 'Email',
    label: 'parismendones@gmail.com',
    href: 'mailto:parismendones@gmail.com',
    note: 'Best for project conversations',
  },
  {
    eyebrow: 'LinkedIn',
    label: 'in/paris-mendones',
    href: 'https://www.linkedin.com/in/paris-mendones-507580329',
    note: 'Connect or message',
    external: true,
  },
  {
    eyebrow: 'Resume',
    label: 'View resume',
    href: '/resume.pdf',
    note: 'Most recent version',
    external: true,
  },
  {
    eyebrow: 'Portfolio',
    label: 'See the work',
    href: '/projects',
    note: 'Seven projects so far',
  },
];
---

<Base
  title="Contact"
  description="Get in touch with Paris Mendones — email, LinkedIn, resume, or a direct message."
>
  <section class="container-wide pt-12 md:pt-20 pb-16 md:pb-24">
    <Reveal>
      <p class="eyebrow">Contact</p>
    </Reveal>
    <div class="mt-8 md:mt-12 grid grid-cols-1 md:grid-cols-12 gap-x-10 gap-y-10 items-end">
      <Reveal class="md:col-span-8" delay={80}>
        <h1
          class="font-display tracking-tight"
          style="font-size: var(--text-display); line-height: var(--text-display-line-height);"
        >
          Let's <span class="italic font-light">talk</span><br />
          <span class="text-blush-deep">about beauty.</span>
        </h1>
      </Reveal>
      <Reveal class="md:col-span-4" delay={140}>
        <p class="text-lg text-ink-soft leading-relaxed max-w-[36ch]">
          Open to internships, projects, and conversations. Pick the channel that fits
          &mdash; or send a note below and I'll get back to you.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="container-wide pb-20 md:pb-28">
    <Reveal>
      <p class="eyebrow">Four ways to reach me</p>
    </Reveal>
    <div class="mt-8 md:mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {ctas.map((cta, i) => (
        <Reveal delay={i * 80}>
          <a
            href={cta.href}
            data-hover-lift
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener noreferrer' : undefined}
            class="group block border border-rule rounded-2xl p-6 md:p-7 hover:border-ink transition-colors h-full"
          >
            <p class="eyebrow">{cta.eyebrow}</p>
            <p class={`font-display mt-5 leading-[1.1] tracking-tight break-words ${cta.label.length > 18 ? 'text-lg md:text-xl' : 'text-2xl md:text-[26px]'}`}>
              {cta.label}
              <span aria-hidden="true" class="inline-block ml-1 text-blush-deep transition-transform group-hover:translate-x-1">→</span>
            </p>
            <p class="mt-3 text-sm text-ink-mute">{cta.note}</p>
          </a>
        </Reveal>
      ))}
    </div>
  </section>

  <section class="bg-ink text-parchment py-24 md:py-32">
    <div class="container-wide grid grid-cols-1 md:grid-cols-12 gap-x-10 gap-y-12">
      <Reveal class="md:col-span-5">
        <p class="eyebrow !text-parchment/60">Or send a note</p>
        <h2
          class="font-display mt-5 tracking-tight max-w-[16ch]"
          style="font-size: var(--text-h1); line-height: var(--text-h1-line-height);"
        >
          The direct line.
        </h2>
        <p class="mt-8 text-parchment/75 leading-relaxed max-w-[38ch]">
          A short message goes a long way. Tell me what you're building, what you're hiring for,
          or what you just want to chat about.
        </p>
      </Reveal>

      <Reveal class="md:col-span-7" delay={100}>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6 md:space-y-7"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="block">
              <span class="block text-xs uppercase tracking-[0.18em] text-parchment/60">Your name</span>
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                class="mt-2 w-full bg-transparent border-b border-parchment/30 focus:border-blush text-parchment text-lg py-3 outline-none transition-colors"
              />
            </label>
            <label class="block">
              <span class="block text-xs uppercase tracking-[0.18em] text-parchment/60">Email</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="mt-2 w-full bg-transparent border-b border-parchment/30 focus:border-blush text-parchment text-lg py-3 outline-none transition-colors"
              />
            </label>
          </div>

          <label class="block">
            <span class="block text-xs uppercase tracking-[0.18em] text-parchment/60">Company / brand (optional)</span>
            <input
              type="text"
              name="company"
              autocomplete="organization"
              class="mt-2 w-full bg-transparent border-b border-parchment/30 focus:border-blush text-parchment text-lg py-3 outline-none transition-colors"
            />
          </label>

          <label class="block">
            <span class="block text-xs uppercase tracking-[0.18em] text-parchment/60">Message</span>
            <textarea
              name="message"
              required
              rows="5"
              class="mt-2 w-full bg-transparent border-b border-parchment/30 focus:border-blush text-parchment text-lg py-3 outline-none transition-colors resize-none"
            ></textarea>
          </label>

          <div class="pt-2 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <p class="text-xs text-parchment/50">Usually replies within a week.</p>
            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-blush text-ink px-6 py-3.5 rounded-full text-sm tracking-wide hover:bg-parchment transition-colors"
            >
              Send message <span aria-hidden="true">→</span>
            </button>
          </div>
        </form>
      </Reveal>
    </div>
  </section>
</Base>
