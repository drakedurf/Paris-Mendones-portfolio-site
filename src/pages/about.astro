---
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';

const interests = [
  {
    number: '01',
    title: 'Brand Strategy & Positioning',
    blurb: 'Finding the reason a brand exists, then making every decision answer back to it.',
  },
  {
    number: '02',
    title: 'Product Development & Launch',
    blurb: 'From whitespace to shelf — the messy, exciting middle where a real thing gets made.',
  },
  {
    number: '03',
    title: 'Marketing & Campaigns',
    blurb: 'How a product moves: the audience read, the channel mix, the creative that makes someone care.',
  },
];

const ctas = [
  {
    eyebrow: 'Email',
    label: 'parismendones@gmail.com',
    href: 'mailto:parismendones@gmail.com',
    note: 'Best for project conversations',
  },
  {
    eyebrow: 'LinkedIn',
    label: 'in/paris-mendones',
    href: 'https://www.linkedin.com/in/paris-mendones-507580329',
    note: 'Connect, message, the usual',
    external: true,
  },
  {
    eyebrow: 'Resume',
    label: 'View resume',
    href: '/resume.pdf',
    note: 'Most recent version',
    external: true,
  },
  {
    eyebrow: 'Portfolio',
    label: 'See the work',
    href: '/projects',
    note: 'Seven projects so far',
  },
];
---

<Base
  title="About"
  description="Paris Mendones — junior at SCAD studying Business of Beauty & Fragrance. Open to brand strategy, product development, and marketing opportunities."
>
  <section class="container-wide pt-12 md:pt-20 pb-20 md:pb-28">
    <Reveal>
      <p class="eyebrow">About</p>
    </Reveal>

    <div class="mt-8 md:mt-12 grid grid-cols-1 md:grid-cols-12 gap-x-10 gap-y-12 items-start">
      <div class="md:col-span-7 md:pt-6">
        <Reveal delay={80}>
          <h1
            class="font-display tracking-tight"
            style="font-size: var(--text-display); line-height: var(--text-display-line-height);"
          >
            Hi —<br />
            I'm <span class="text-blush-deep">Paris Mendones.</span>
          </h1>
        </Reveal>

        <Reveal delay={160}>
          <p class="mt-8 md:mt-10 text-xl md:text-2xl text-ink-soft leading-[1.4] max-w-[34ch] font-serif italic font-light">
            A junior at SCAD studying Business of Beauty &amp; Fragrance, heading
            into senior year. Open to wherever beauty meets business — brand,
            product, and the work of building both.
          </p>
        </Reveal>

        <Reveal delay={220}>
          <p class="mt-6 text-sm text-ink-mute italic">
            <span class="not-italic">↳</span> Placeholder headline copy &mdash; review and edit in your own voice.
          </p>
        </Reveal>
      </div>

      <div class="md:col-span-5">
        <Reveal delay={120}>
          <ImagePlaceholder
            label="Paris Mendones — portrait"
            aspectRatio="4/5"
            src="/about/portrait.jpg"
            tone="warm"
            rounded
            priority
          />
        </Reveal>
      </div>
    </div>
  </section>

  <section class="container-wide py-20 md:py-28 border-t border-rule/60">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-10 gap-y-10">
      <div class="md:col-span-3">
        <Reveal>
          <p class="eyebrow">The short version</p>
        </Reveal>
      </div>
      <div class="md:col-span-9">
        <Reveal delay={60}>
          <div class="prose prose-lg max-w-[68ch]
            prose-p:text-ink-soft prose-p:leading-[1.75] prose-p:text-lg
            prose-p:font-normal
            prose-strong:text-ink prose-strong:font-semibold">
            <p>
              I'm a junior at the Savannah College of Art and Design pursuing a
              <strong>B.F.A. in the Business of Beauty &amp; Fragrance</strong> with a
              minor in Business Management &amp; Entrepreneurship.
            </p>
            <p>
              I'm drawn to the marketing and product development side of beauty:
              the strategy behind a launch, the consumer it's built for, and the
              way a brand earns a place in someone's day. The projects that have
              pulled me in the most sit at the intersection of three things:
              <strong>brand strategy, consumer research, and product development.</strong>
              Three lenses on the same question. How do beauty brands build something
              people actually want to come back to?
            </p>
            <p>
              My work has spanned global market expansion, prestige competitive
              analysis, and whitespace product development for an established
              fashion brand. Different scopes, same instinct. Start with the
              consumer, then build everything else around her.
            </p>
            <p>
              When I'm not in class, I compete on SCAD's Women's Bowling Team and
              serve on its leadership council. Competing since childhood has
              taught me the same things that drive my work in beauty: discipline,
              attention to detail, and showing up consistently. It's the mindset
              I bring to every project.
            </p>
            <p>
              I'm open to internships, projects, and conversations at indie
              houses, legacy brands, and everywhere in between. If you're building
              something in beauty, fragrance, or luxury and you want another set
              of eyes, I'd love to hear about it.
            </p>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <section class="bg-ink text-parchment py-24 md:py-32">
    <div class="container-wide">
      <Reveal>
        <p class="eyebrow !text-parchment/60">What I'm interested in</p>
        <h2
          class="font-display mt-5 tracking-tight max-w-[18ch]"
          style="font-size: var(--text-h1); line-height: var(--text-h1-line-height);"
        >
          Three lenses on the same question.
        </h2>
      </Reveal>

      <div class="mt-14 md:mt-20 grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-12">
        {interests.map((item, i) => (
          <Reveal delay={i * 100}>
            <article class="border-t border-parchment/15 pt-6">
              <p class="font-display text-blush text-2xl tabular-nums">{item.number}</p>
              <h3 class="font-display mt-3 text-2xl md:text-[28px] leading-[1.1] tracking-tight">{item.title}</h3>
              <p class="mt-5 text-parchment/80 leading-relaxed">{item.blurb}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="container-wide py-20 md:py-28">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-10 gap-y-10">
      <div class="md:col-span-3">
        <Reveal>
          <p class="eyebrow">Quick facts</p>
        </Reveal>
      </div>
      <div class="md:col-span-9">
        <Reveal delay={60}>
          <dl class="space-y-5 md:space-y-6 text-lg">
            <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-y-1 md:gap-x-8 border-b border-rule/60 pb-5 md:pb-6">
              <dt class="text-ink-mute text-sm md:text-base tracking-wide">School</dt>
              <dd class="font-display text-xl md:text-2xl tracking-tight">Savannah College of Art and Design (SCAD)</dd>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-y-1 md:gap-x-8 border-b border-rule/60 pb-5 md:pb-6">
              <dt class="text-ink-mute text-sm md:text-base tracking-wide">Major</dt>
              <dd class="font-display text-xl md:text-2xl tracking-tight">Business of Beauty &amp; Fragrance</dd>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-y-1 md:gap-x-8 border-b border-rule/60 pb-5 md:pb-6">
              <dt class="text-ink-mute text-sm md:text-base tracking-wide">Class year</dt>
              <dd class="font-display text-xl md:text-2xl tracking-tight">Junior &mdash; heading into senior year</dd>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-y-1 md:gap-x-8">
              <dt class="text-ink-mute text-sm md:text-base tracking-wide">Expected B.F.A.</dt>
              <dd class="font-display text-xl md:text-2xl tracking-tight">May 2027</dd>
            </div>
          </dl>
        </Reveal>
      </div>
    </div>
  </section>

  <section class="container-wide pb-20 md:pb-32">
    <Reveal>
      <div class="border-t border-rule/60 pt-10 md:pt-14 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <p class="eyebrow">Get in touch</p>
          <h2
            class="font-display mt-4 tracking-tight max-w-[22ch]"
            style="font-size: var(--text-h2); line-height: var(--text-h2-line-height);"
          >
            Four ways to reach out, all equally welcome.
          </h2>
        </div>
        <p class="text-ink-soft max-w-[36ch] leading-relaxed">
          Whether you have a role, a project, or just a thought worth sharing &mdash; pick the one that fits.
        </p>
      </div>
    </Reveal>

    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {ctas.map((cta, i) => (
        <Reveal delay={i * 80}>
          <a
            href={cta.href}
            data-hover-lift
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener noreferrer' : undefined}
            class="group block border border-rule rounded-2xl p-6 md:p-7 hover:border-ink transition-colors h-full"
          >
            <p class="eyebrow">{cta.eyebrow}</p>
            <p class="font-display mt-5 text-2xl md:text-[26px] leading-[1.1] tracking-tight">
              {cta.label}
              <span aria-hidden="true" class="inline-block ml-1 text-blush-deep transition-transform group-hover:translate-x-1">→</span>
            </p>
            <p class="mt-3 text-sm text-ink-mute">{cta.note}</p>
          </a>
        </Reveal>
      ))}
    </div>
  </section>
</Base>
