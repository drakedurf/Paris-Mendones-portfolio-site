---
interface StageImage {
  label: string;
  src?: string;
}

interface Props {
  images: StageImage[];
  bodySelector?: string;
}

const { images, bodySelector = '[data-project-body]' } = Astro.props;
---

<div class="project-stage" data-project-stage data-body-selector={bodySelector}>
  <div class="stage-inner">
    {images.map((img, i) => (
      <div
        class={`stage-layer ${i === 0 ? 'is-active' : ''}`}
        data-stage-layer={i}
        aria-hidden={i === 0 ? 'false' : 'true'}
      >
        {img.src ? (
          <img
            src={img.src}
            alt={img.label}
            class="stage-img"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ) : (
          <div class="stage-placeholder">
            <span class="eyebrow px-6 text-center">{img.label}</span>
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="stage-progress" aria-hidden="true">
    {images.map((_, i) => (
      <span class={`tick ${i === 0 ? 'is-active' : ''}`} data-stage-tick={i}></span>
    ))}
  </div>
</div>

<style>
  .project-stage {
    position: sticky;
    top: 6rem;
    height: calc(100vh - 8rem);
    max-height: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stage-inner {
    position: relative;
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
  }

  .stage-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.985);
    transition: opacity 0.8s cubic-bezier(0.2, 0.65, 0.2, 1),
                transform 1.4s cubic-bezier(0.2, 0.65, 0.2, 1);
    will-change: opacity, transform;
    border-radius: 1rem;
    overflow: hidden;
  }
  .stage-layer.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .stage-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stage-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-parchment-warm, #efe8de);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink-mute);
  }

  .stage-progress {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
  }
  .tick {
    width: 1.4rem;
    height: 2px;
    background: rgba(0, 0, 0, 0.18);
    border-radius: 9999px;
    transition: background-color 0.4s, width 0.4s;
  }
  .tick.is-active {
    background: var(--color-ink);
    width: 2.4rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .stage-layer {
      transition: opacity 0.15s linear;
      transform: none;
    }
    .stage-layer.is-active { transform: none; }
  }
</style>

<script>
  const stages = document.querySelectorAll<HTMLElement>('[data-project-stage]');

  stages.forEach((stage) => {
    const layers = Array.from(stage.querySelectorAll<HTMLElement>('.stage-layer'));
    const ticks = Array.from(stage.querySelectorAll<HTMLElement>('.tick'));
    const total = layers.length;
    if (total <= 1) return;

    const bodySelector = stage.dataset.bodySelector || '[data-project-body]';
    const body = document.querySelector<HTMLElement>(bodySelector);
    if (!body) return;

    let current = 0;
    let ticking = false;

    const setActive = (idx: number) => {
      const clamped = Math.max(0, Math.min(total - 1, idx));
      if (clamped === current) return;
      current = clamped;
      layers.forEach((layer, i) => {
        const active = i === current;
        layer.classList.toggle('is-active', active);
        layer.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      ticks.forEach((tick, i) => {
        tick.classList.toggle('is-active', i === current);
      });
    };

    const compute = () => {
      ticking = false;
      const rect = body.getBoundingClientRect();
      const viewportH = window.innerHeight;
      // Position of the viewport's reading line within the body, in body coords.
      // Reading line sits 45% down the viewport — slightly above center so the
      // active image leads the section you're starting to read.
      const readingLineY = viewportH * 0.45;
      const positionInBody = readingLineY - rect.top;
      const progress = Math.max(0, Math.min(0.9999, positionInBody / rect.height));
      const idx = Math.floor(progress * total);
      setActive(idx);
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(compute);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    compute();
  });
</script>
